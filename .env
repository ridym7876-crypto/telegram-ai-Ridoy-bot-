# IMPORTANT: Sensitive values were removed from this committed .env.
# If your BOT_TOKEN was exposed in this repository, revoke it immediately from Telegram BotFather and generate a new token.
# Add real values to a local (untracked) .env file before running.

BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
BASE44_API_KEY=YOUR_BASE44_API_KEY
USE_BASE44=true
MONGODB_URI=YOUR_MONGODB_URI
